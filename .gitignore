# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js — excluir build completo, pero force-add selectivo en deploy
/.next/
/out/
# Dev cache de Turbopack (archivos gigantes, no necesarios en producción)
/.next/dev/
/.next/cache/

# production
/build

# misc
.DS_Store
*.pem

# Claude Code — configuración local con credenciales, no va al repo
.claude/
.firecrawl/
.mcp.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — nunca commitear secretos reales
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example SÍ se commitea (solo tiene placeholders)
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env.local
